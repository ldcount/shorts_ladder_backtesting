[Unit]
Description=Backtesting Codex Production Runner
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/bots/backtesting_codex_local
ExecStart=/opt/bots/backtesting_codex_local/venv/bin/python /opt/bots/backtesting_codex_local/new.py
Restart=on-failure
RestartSec=10
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
